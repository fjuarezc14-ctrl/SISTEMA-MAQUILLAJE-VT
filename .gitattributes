# Normalizar finales de línea automáticamente
* text=auto

# Archivos que siempre deben ser LF (Unix)
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.env* text eol=lf
.gitignore text eol=lf
