# =============================================
# GLOWMANAGER PRO — Variables de Entorno
# =============================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Completa los valores con tus datos reales
#   3. NUNCA subas el archivo .env al repositorio
# =============================================

# ----- ENTORNO -----
# Valores posibles: development | production
NODE_ENV=development

# ----- BASE DE DATOS (PostgreSQL) -----
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
# Desarrollo local (Docker):
DATABASE_URL="postgresql://glowmanager:glowpassword123@localhost:5437/glowmanager_db"

# Producción (completar con datos del servidor):
# DATABASE_URL="postgresql://USUARIO_PROD:PASSWORD_PROD@HOST_PROD:5432/NOMBRE_BD_PROD"

# ----- BACKEND -----
BACKEND_PORT=3003

# Clave secreta para JWT — usar una cadena larga y aleatoria
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga_y_segura
JWT_EXPIRES_IN=7d

# CORS — Origen permitido para el frontend
# Desarrollo local:
CORS_ORIGIN=http://localhost:5175
# Producción:
# CORS_ORIGIN=https://tudominio.com

# ----- FRONTEND -----
# URL del backend que usará el frontend
# Desarrollo local:
VITE_API_URL=http://localhost:3003/api
# Producción:
# VITE_API_URL=https://api.tudominio.com/api

# ----- DOCKER COMPOSE (solo para docker-compose.yml) -----
POSTGRES_USER=glowmanager
POSTGRES_PASSWORD=glowpassword123
POSTGRES_DB=glowmanager_db
