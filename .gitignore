# =============================================
# GLOWMANAGER PRO — .gitignore
# =============================================

# ----- ENTORNO Y SECRETOS (NUNCA AL REPO) -----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ----- DEPENDENCIAS -----
node_modules/
frontend/node_modules/
backend/node_modules/

# ----- BUILD / DIST -----
frontend/dist/
frontend/build/
backend/dist/

# ----- PRISMA -----
# Las migraciones SÍ van al repo, solo ignoramos lo generado
backend/prisma/dev.db
backend/prisma/dev.db-journal

# ----- LOGS -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----- DOCKER -----
# Los volúmenes locales de Docker no van al repo
docker/volumes/
postgres_data/

# ----- EDITORES -----
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----- TESTING -----
coverage/
.nyc_output/

# ----- CACHE -----
.eslintcache
.parcel-cache/
.vite/
